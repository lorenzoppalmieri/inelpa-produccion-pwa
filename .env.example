# Copia este archivo a `.env.local` y completá los valores reales.
# NO commitees .env.local al repo.

# URL del proyecto Supabase (ej: https://xxxxx.supabase.co)
VITE_SUPABASE_URL=

# Anon/public key del proyecto Supabase
# (La seguridad se resuelve con RLS en Postgres, no ocultando esta key)
VITE_SUPABASE_ANON_KEY=

# PIN de 4 dígitos para acceder al panel admin (/admin).
# Si no se setea, usa "9999" como fallback de desarrollo.
# En producción, cambiarlo en el .env.local de cada PC panel.
VITE_ADMIN_PIN=

# PIN de 4 dígitos para acceder al tablero de supervisor (/supervisor).
# Permite a jefes de sector ver el tablero en vivo sin tener permisos
# de admin (crear/cancelar órdenes). Fallback "8888" en dev.
VITE_SUPERVISOR_PIN=

# Dejar vacío en producción. Poner "1" si querés probar el service worker
# durante `npm run dev` en local.
VITE_ENABLE_PWA_DEV=
